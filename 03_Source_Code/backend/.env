# ==========================================
# KONFIGURASI LOKAL (DOCKER COMPOSE)
# ==========================================

# 1. Konfigurasi untuk container PostgreSQL (service 'db')
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lostandfound

# 2. Koneksi Database untuk backend
# Karena berjalan di dalam docker, host-nya adalah nama service database yaitu 'db'
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/lostandfound

# 3. Pengaturan Storage
# Gunakan penyimpanan lokal, file akan disimpan di folder ./storage
STORAGE_PROVIDER=local
CLAIM_UPLOAD_DIR=storage/claims
IDENTITY_DOCUMENT_UPLOAD_DIR=storage/identity-documents

# 4. Keamanan
SECRET_KEY="secret-key-lokal-bebas-apa-saja"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 5. CORS (Untuk integrasi dengan frontend lokal)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
